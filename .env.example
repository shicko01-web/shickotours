# shickotours environment variables
# Copy this file to `.env` and fill in your keys.

# OpenWeatherMap — https://openweathermap.org/api  (free tier: 1000 calls/day)
VITE_OPENWEATHER_API_KEY=

# Google Maps JavaScript API — https://console.cloud.google.com/google/maps-apis
# Required APIs: Maps JavaScript API, Places API
# IMPORTANT: restrict your key by HTTP referrer in Google Cloud Console!
VITE_GOOGLE_MAPS_API_KEY=

# Optional — set this when building for GitHub Pages (must include trailing slash)
# Example: VITE_BASE=/shickotours/
# VITE_BASE=/
